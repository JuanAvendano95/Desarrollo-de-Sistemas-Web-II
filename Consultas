USE TiendaSara;
GO

-- 1. Consultar los productos con sus marcas y sus categorías
SELECT P.Descripcion AS Producto, P.Precio, M.Descripcion AS Marca, C.Descripcion AS Categoria
FROM PRODUCTOS P
INNER JOIN MARCAS M ON P.IdMarca = M.Id
INNER JOIN CATEGORIAS C ON P.IdCategoria = C.Id;

-- 2. Consultar los carritos con sus carritos detalle y sus productos
SELECT C.FolioVenta, C.Estatus, CD.Cantidad, CD.Subtotal, P.Descripcion AS Producto
FROM CARRITO C
INNER JOIN CARRITO_DETALLE CD ON C.Id = CD.IdCarrito
INNER JOIN PRODUCTOS P ON CD.IdProducto = P.Id;

-- 3. Consultar los carritos con sus carritos detalle, productos, marcas y categorías
SELECT C.FolioVenta, C.Fecha, P.Descripcion AS Producto, M.Descripcion AS Marca, Cat.Descripcion AS Categoria, CD.Subtotal
FROM CARRITO C
INNER JOIN CARRITO_DETALLE CD ON C.Id = CD.IdCarrito
INNER JOIN PRODUCTOS P ON CD.IdProducto = P.Id
INNER JOIN MARCAS M ON P.IdMarca = M.Id
INNER JOIN CATEGORIAS Cat ON P.IdCategoria = Cat.Id;
GO
